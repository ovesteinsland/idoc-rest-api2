<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

  <display-name>Archetype Created Web Application</display-name>
  <servlet>
    <servlet-name>Jersey Web Application</servlet-name>
    <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
    <init-param>
      <param-name>jersey.config.server.provider.packages</param-name>
      <param-value>no.softwarecontrol.idoc.webservices.restapi;no.softwarecontrol.idoc.filter</param-value>
    </init-param>

    <load-on-startup>0</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>Jersey Web Application</servlet-name>
    <url-pattern>/iDocWebServices/webresources/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>SignupCustomerServlet</servlet-name>
    <servlet-class>no.softwarecontrol.idoc.web.signup.SignupCustomerServlet</servlet-class>
    <load-on-startup>0</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>SignupCustomerServlet</servlet-name>
    <url-pattern>/iDocWebServices/signup</url-pattern>
  </servlet-mapping>

  <filter>
    <filter-name>CorsFilter</filter-name>
    <filter-class>no.softwarecontrol.idoc.filter.CorsFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>CorsFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>BasicAuthenticationFilter</filter-name>
    <filter-class>no.softwarecontrol.idoc.filter.BasicAuthenticationFilter</filter-class>
    <init-param>
      <param-name>username</param-name>
      <param-value>ApplicationUser</param-value>
    </init-param>
    <init-param>
      <param-name>password</param-name>
      <param-value>Ihadthisthing969906</param-value>
    </init-param>
    <init-param>
      <param-name>disableBasicOnPaths</param-name>
      <!--param-value>/iDocWebServices/webresources/no.softwarecontrol.idoc.entityobject.sms,/idoc_rest_api2_war/iDocWebServices/webresources/no.softwarecontrol.idoc.entityobject.sms,/iDocWebServices/webresources/cognito/login,/iDocWebServices/webresources/cognito/register,/iDocWebServices/webresources/cognito/confirm-email,/iDocWebServices/webresources/cognito/tokens,/iDocWebServices/webresources/cognito/refresh-token</param-value-->
    <param-value>/iDocWebServices/webresources/cognito/login,/iDocWebServices/webresources/cognito/register,/iDocWebServices/webresources/cognito/confirm-email,/iDocWebServices/webresources/cognito/tokens,/iDocWebServices/webresources/cognito/refresh-token</param-value>
    </init-param>
  </filter>
  <filter-mapping>
    <filter-name>BasicAuthenticationFilter</filter-name>
    <url-pattern>/iDocWebServices/webresources/*</url-pattern>
  </filter-mapping>

  <resource-ref>
    <description>DB Connection for iDocDatabase</description>
    <res-ref-name>jdbc/iDocDatabase</res-ref-name>
    <res-type>javax.sql.DataSource</res-type>
    <res-auth>Container</res-auth>
    <res-sharing-scope>Shareable</res-sharing-scope>
  </resource-ref>

</web-app>